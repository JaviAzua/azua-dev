---
// Root: detect user language (script) → /es/ or /en/; meta refresh = fallback sin JS
const fallbackLocale = 'en';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="refresh" content={`1;url=/${fallbackLocale}/`} />
  </head>
  <body>
    <script>
      (function () {
        const langs = navigator.languages || [navigator.language];
        const prefersSpanish = langs.some(function (l) {
          return l && l.toLowerCase().startsWith('es');
        });
        window.location.replace('/' + (prefersSpanish ? 'es' : 'en') + '/');
      })();
    </script>
  </body>
</html>
